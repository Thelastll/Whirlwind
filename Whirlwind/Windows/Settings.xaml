<Window x:Class="Whirlwind.Windows.Settings"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Whirlwind.Windows"
        mc:Ignorable="d"
        Title="Settings" Height="580" Width="450">
    <Grid>
        <Grid Margin="20">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <TextBlock Text="Громкость уведомлений"
               FontSize="18"
               Foreground="Black"
               Margin="0 0 0 10"/>

            <!-- Ползунок громкости -->
            <Slider x:Name="VolumeSlider"
            Grid.Row="1"
            Minimum="0"
            Maximum="1"
            Value="0.5"
            TickFrequency="0.1"
            IsSnapToTickEnabled="True"
            VerticalAlignment="Center"
            Background="#3A3A3A"
            Foreground="White"
            ValueChanged="VolumeSlider_ValueChanged">
                <Slider.ToolTip>
                    <ToolTip Content="{Binding PlacementTarget.Value,
                               RelativeSource={RelativeSource Self},
                               StringFormat=F1}"/>
                </Slider.ToolTip>
            </Slider>
        </Grid>
    </Grid>
</Window>
