<Window x:Class="Whirlwind.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Whirlwind"
        mc:Ignorable="d"
        Title="Whirlwind" Height="700" Width="1110"
        ContentRendered="Window_ContentRendered"
        Closing="Window_Closing"
        KeyDown="Window_KeyDown"
        PreviewKeyDown="MainWindow_PreviewKeyDown"
        Loaded="Window_Loaded">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220*"/>
            <ColumnDefinition Width="51*"/>
            <ColumnDefinition Width="78*"/>
            <ColumnDefinition Width="93*"/>
            <ColumnDefinition Width="897*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель -->
        <Border Background="#2B2B2B" Grid.Column="0" Grid.ColumnSpan="4">
            <DockPanel Margin="10">

                <Grid DockPanel.Dock="Top" Margin="0 0 0 10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="settings_button"
                            Content="⚙"
                            Grid.Column="0"
                            MinWidth="40"
                            MinHeight="35"
                            Background="#4A4A4A"
                            Foreground="White"
                            FontSize="18"
                            BorderThickness="0"
                            Margin="0 0 10 0"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center"
                            Click="settings_button_Click"/>

                    <Button x:Name="add_user"
                            Content="+"
                            Grid.Column="1"
                            MinWidth="50"
                            MinHeight="35"
                            Background="#4A4A4A"
                            Foreground="White"
                            FontSize="20"
                            BorderThickness="0"
                            Margin="0 0 10 0"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center"
                            Click="add_device_Click"/>

                    <Button x:Name="change_sender_ipaddress"
                            Content="Изменить IP адрес"
                            Grid.Column="2"
                            MinHeight="35"
                            Background="#3A3A3A"
                            Foreground="White"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center"
                            Click="change_sender_ip_address_Click"/>
                </Grid>

                <ListBox x:Name="DeviceList"
                         DockPanel.Dock="Top"
                         Background="#333"
                         Foreground="White"
                         BorderThickness="0"
                         Margin="0 0 0 10"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Stretch"
                         HorizontalContentAlignment="Stretch">

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10"
                                    Margin="0 0 0 5"
                                    Background="#3A3A3A"
                                    HorizontalAlignment="Stretch"
                                    MouseLeftButtonUp="device_item_Click">

                                <Border.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Изменить"
                                                  Click="update_device_Click"/>
                                        <MenuItem Header="Удалить"
                                                  Click="delete_device_Click"/>
                                    </ContextMenu>
                                </Border.ContextMenu>

                                <StackPanel>
                                    <TextBlock Text="{Binding HiddenId}"
                                               Visibility="Collapsed"/>

                                    <TextBlock Text="{Binding Name}"
                                               FontSize="16"
                                               Foreground="White"/>

                                    <TextBlock Text="{Binding Ip}"
                                               FontSize="12"
                                               Foreground="#CCCCCC"/>
                                </StackPanel>

                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            </DockPanel>
        </Border>

        <!-- Правая панель -->
        <Grid Grid.Column="4" Margin="10,10,10,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <!-- список файлов -->
                <RowDefinition Height="Auto"/>
                <!-- ввод -->
            </Grid.RowDefinitions>

            <Grid Background="#3A3A3A" Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="ChatTitle"
                           Text="_"
                           FontSize="18"
                           Background="#3A3A3A"
                           Foreground="White"
                           Margin="10 0 10 0"/>
                    <TextBlock x:Name="IpTitle"
                           Text="_"
                           FontSize="14"
                           Background="#3A3A3A"
                           Foreground="#CCCCCC"
                           Margin="10 0 10 0"/>
                </StackPanel>

                <Button x:Name="mute_button"
                        Grid.Column="1"
                        Content="🔇"
                        MinWidth="50"
                        MinHeight="35"
                        Background="#555"
                        Foreground="White"
                        FontSize="20"
                        Visibility="Collapsed"
                        BorderThickness="0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Click="mute_button_Click"/>
            </Grid>


            <!-- Сообщения -->
            <ScrollViewer x:Name="MessagesScroll"
                          Grid.Row="1"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="MessagesPanel"
                            Margin="0 5 0 10"/>
            </ScrollViewer>

            <!-- Список прикреплённых файлов -->
            <ListBox x:Name="AttachedFilesList"
                     Grid.Row="2"
                     Visibility="Collapsed"
                     Background="Transparent"
                     Foreground="White"
                     BorderThickness="0"
                     HorizontalAlignment="Stretch"
                     VerticalAlignment="Top"
                     MaxHeight="120"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     PreviewMouseWheel="attached_files_list_PreviewMouseWheel">


                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#3A3A3A"
                Padding="4"
                Margin="0 0 0 3">

                            <Border.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Удалить"
                              Click="attached_file_delete_Click"/>
                                </ContextMenu>
                            </Border.ContextMenu>

                            <TextBlock Text="{Binding}"
                       FontSize="12"
                       Foreground="White"/>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>


            </ListBox>

            <!-- Поле ввода + кнопки -->
            <Grid Grid.Row="3" Margin="0 10 0 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="message"
                         Grid.Column="0"
                         MinHeight="40"
                         MaxHeight="200"
                         FontSize="16"
                         Background="#2B2B2B"
                         Foreground="White"
                         BorderThickness="1"
                         BorderBrush="#555"
                         VerticalAlignment="Center"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"/>

                <Button x:Name="attach_file_button"
                        Grid.Column="1"
                        Content="📎"
                        MinWidth="60"
                        MinHeight="40"
                        Background="#555"
                        Foreground="White"
                        FontSize="20"
                        BorderThickness="0"
                        VerticalAlignment="Center"
                        Click="attach_file_button_Click"/>

                <Button x:Name="send_button"
                        Grid.Column="2"
                        Content="→"
                        MinWidth="60"
                        MinHeight="40"
                        Background="#007ACC"
                        Foreground="White"
                        FontSize="20"
                        BorderThickness="0"
                        VerticalAlignment="Center"
                        Click="send_button_Click"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
