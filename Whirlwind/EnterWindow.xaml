        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Whirlwind"
        mc:Ignorable="d"
        Title="EnterWindow" Height="236" Width="479" WindowStartupLocation="CenterOwner" ShowInTaskbar="False" WindowStyle="ToolWindow" Closing="Window_Closing" ContentRendered="Window_ContentRendered"
        KeyDown="enter_text_KeyDown" Icon="/WhirlwindSilver.ico">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <TextBox x:Name="ip">
            
        </TextBox>

        <Button x:Name="enter_button" Grid.Row="1" Click="enter_Click">
            использовать этот ip
        </Button>
    </Grid>
</Window>
